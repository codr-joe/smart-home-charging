# Base URL of the API server used by the SvelteKit server-side load functions.
API_BASE_URL=http://localhost:8080

# Base URL of the API server used by client-side fetch calls.
# In production this is left empty (relative URLs are used via same-origin routing).
# In local development the API runs on a different port, so set this explicitly.
VITE_API_BASE_URL=http://localhost:8080
