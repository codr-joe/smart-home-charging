# PostgreSQL/TimescaleDB connection string.
# Matches the credentials defined in docker-compose.yml.
DATABASE_URL=postgres://smartcharging:smartcharging@localhost:5432/smartcharging

# URL of the HomeWizard P1 meter on your local network.
# When running the local mock (make mock-p1), use http://localhost:8090
P1_METER_URL=http://localhost:8090

# Address the API server binds to. Defaults to :8080 if unset.
LISTEN_ADDR=:8080

# Pushover notification credentials (optional).
# When both values are set the API sends alerts when excess solar power
# crosses 1 000 W, every 500 W increment above that, and when it drops below 500 W.
# Leave empty to disable notifications.
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=
